{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "perf": "error",
    "suspicious": "error"
  },
  "env": {
    "browser": true,
    "node": true
  },
  "plugins": ["typescript", "react", "react-hooks", "jsx-a11y"],
  "rules": {
    "no-console": "warn",
    "react/jsx-filename-extension": "off",
    "react/react-in-jsx-scope": "off"
  }
}
